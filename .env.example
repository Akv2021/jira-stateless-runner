# jira-stateless-runner — environment variable template.
#
# Copy to `.env` (gitignored) and fill in real values before running the
# runner or the Phase 1 provisioning script locally. The loader is the
# same in both consumers (pydantic-settings, case-insensitive); missing
# or malformed values cause a fail-fast ValidationError at startup.
#
# Consumers:
#   - runner.config.Settings              — reads JIRA_URL / JIRA_USER /
#                                           JIRA_TOKEN / JIRA_PROJECT_KEY
#                                           / AGING_THRESHOLD_DAYS
#   - scripts/provision_jira.py           — reads JIRA_URL / JIRA_EMAIL
#                                           (alias JIRA_USER) / JIRA_TOKEN
#                                           / JIRA_ACCOUNT_ID

# --- Shared by both runner and provisioner -------------------------------
# Base URL of the Jira Cloud / Server instance. Must be http:// or https://.
JIRA_URL=https://example.atlassian.net

# Email address used for Jira API Basic-auth (pairs with JIRA_TOKEN).
# Accepted by both runner.config (as JIRA_USER) and provision_jira.py
# (as JIRA_EMAIL, with JIRA_USER recognised as an alias).
JIRA_USER=bot@example.com

# Jira API token; generate at https://id.atlassian.com/manage-profile/security/api-tokens
# and treat as a secret — never commit real values.
JIRA_TOKEN=replace-me

# --- Runner-only ---------------------------------------------------------
# Target Jira project key: 2-10 upper-case letters, e.g. "PROJ".
JIRA_PROJECT_KEY=PROJ

# T9 staleness threshold in calendar days (LivingRequirements.md §5.2 T9).
# Default operational value is 90; override for staging / test tuning.
AGING_THRESHOLD_DAYS=90

# --- Provisioner-only (scripts/provision_jira.py) ------------------------
# Atlassian accountId used as `leadAccountId` on project create.
# Retrieve via:
#   curl -s -u "$JIRA_USER:$JIRA_TOKEN" \
#        "$JIRA_URL/rest/api/3/myself" | jq -r .accountId
JIRA_ACCOUNT_ID=000000:00000000-0000-0000-0000-000000000000
